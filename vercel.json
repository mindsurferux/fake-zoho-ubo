{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/oauth/(.*)", "destination": "/api/index.js" },
    { "source": "/admin/(.*)", "destination": "/api/index.js" },
    { "source": "/health/(.*)", "destination": "/api/index.js" },
    { "source": "/health", "destination": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  }
}
